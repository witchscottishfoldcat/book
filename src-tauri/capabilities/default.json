{
  "identifier": "default",
  "description": "Default capabilities for MDNotes",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:path:default",
    "fs:default",
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-appdata-read-recursive",
    "fs:allow-appdata-write-recursive",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "shell:allow-open"
  ]
}
